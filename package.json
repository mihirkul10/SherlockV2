{
  "name": "sherlock-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SherlockV2 — Cursor-native personal research analyst. Cloud-scheduled ingestion + local two-tier agent (Front orchestrator + Researcher sub-agents).",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "build": "tsc",
    "bridge": "tsx src/bridge/index.ts",
    "bridge:dev": "tsx watch src/bridge/index.ts",
    "admin": "tsx src/admin/index.ts",
    "admin:dev": "tsx watch src/admin/index.ts",
    "ingest": "tsx src/scripts/ingest-once.ts",
    "resolve:youtube": "tsx src/scripts/resolve-youtube-handles.ts",
    "resolve:twitter": "tsx src/scripts/resolve-twitter-handles.ts",
    "smoke:sdk": "tsx src/scripts/sdk-smoke.ts",
    "list:models": "tsx src/scripts/list-models.ts",
    "seed:sources": "tsx src/scripts/seed-sources.ts",
    "context:api": "tsx src/retrieval/api-server.ts",
    "index:cloud": "tsx src/scripts/cloud-index-sync.ts",
    "check:freshness": "tsx src/scripts/check-index-freshness.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@cursor/sdk": "^1.0.12",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "apify-client": "^2.12.6",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^17.3.1",
    "nanoid": "^5.1.5",
    "pino": "^9.8.0",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
