<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sherlock.index-freshness</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>source $HOME/.nvm/nvm.sh &amp;&amp; cd /Users/sherlockkulkarni/Projects/SherlockV2 &amp;&amp; npm run check:freshness 2&gt;&amp;1</string>
