# SherlockV2 — local environment configuration.
# The real .env is symlinked from ~/.sherlock/.env on the dedicated Sherlock Mac
# (same convention as SherlockKulkarni). This file documents the variables.

# ─── Cursor SDK ──────────────────────────────────────────────────────────────
# The only auth the SDK needs (https://cursor.com/dashboard/cloud-agents → API Keys).
# Used by every Agent.create / Agent.prompt / Agent.resume call.
CURSOR_API_KEY=

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Fine-grained PAT with `repo` write scope on sherlock-context + sherlock-vault.
# Used by cloud ingestion agents (push) and local researchers (push reports).
SHERLOCK_GITHUB_PAT=

# ─── Web search (Parallel only — see plan §7.5) ─────────────────────────────
PARALLEL_API_KEY=

# ─── YouTube ─────────────────────────────────────────────────────────────────
# YouTube Data API v3 key for handle resolution + uploads listing.
YOUTUBE_API_KEY=
# Apify token for the starvibe/youtube-video-transcript actor.
APIFY_API_TOKEN=

# ─── X / Twitter ─────────────────────────────────────────────────────────────
# App-only bearer for timeline reads of the 4 followed people.
TWITTER_BEARER_TOKEN=
# (M4 only) OAuth user-context for the bookmarks endpoint.
X_OAUTH_CONSUMER_KEY=
X_OAUTH_CONSUMER_SECRET=
X_OAUTH_REFRESH_TOKEN=

# ─── Substack ────────────────────────────────────────────────────────────────
# (M4 only, optional) substack.sid cookie value for auto-enumerate subscriptions.
# If empty, the agent uses the explicit subdomain list from sources.json.
SUBSTACK_SESSION_COOKIE=

# ─── BlueBubbles (iMessage bridge) ──────────────────────────────────────────
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_URL=http://localhost:1234
ADMIN_IMESSAGE=

# ─── Local paths ─────────────────────────────────────────────────────────────
SHERLOCK_PROJECT_ROOT=/Users/sherlockkulkarni/Projects/SherlockV2
SHERLOCK_CONTEXT_PATH=/Users/sherlockkulkarni/Projects/sherlock-context
SHERLOCK_VAULT_PATH=/Users/sherlockkulkarni/Projects/sherlock-vault

# ─── Bridge HTTP server ──────────────────────────────────────────────────────
BRIDGE_PORT=18790

# ─── Optional: Voyage embeddings (off by default in M2; on in M4 if needed) ──
VOYAGE_API_KEY=

# ─── Optional: Obsidian Local REST API (already set up; not used in MVP) ────
OBSIDIAN_REST_API_KEY=
OBSIDIAN_REST_API_URL=
